---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Products | SaiWei Sport Custom Football, Basketball, Teamwear & Shin Guards"
  description="Explore SaiWei Sport custom sports goods including footballs, football uniforms, basketballs, basketball uniforms and shin guards."
  activePage="products"
>
  <main>
    <section class="pagehero">
      <div class="container">
        <div class="label"><span></span> SaiWei Sport Product Line</div>
        <h1>Custom football, basketball, teamwear and protective gear.</h1>
        <p class="lead">Build your own sports product catalog with flexible OEM/ODM options for wholesale, private label, team projects and marketplace supply.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="grid3">
          <article class="card">
            <div class="icon">⚽</div>
            <h3>Custom Footballs</h3>
            <p>Training balls, match balls and promotional footballs with brand logo, panel colors and packaging.</p>
            <ul class="list">
              <li>Logo printing and color customization</li>
              <li>PU / PVC / training and match options</li>
              <li>Retail carton and bulk packing support</li>
            </ul>
          </article>
          <article class="card">
            <div class="icon">👕</div>
            <h3>Football Uniforms</h3>
            <p>Full team kits for clubs, schools and distributors with sublimation graphics and team identity.</p>
            <ul class="list">
              <li>Jerseys, shorts and full kits</li>
              <li>Names, numbers, club badges and sponsors</li>
              <li>Youth and adult size ranges</li>
            </ul>
          </article>
          <article class="card">
            <div class="icon">🏀</div>
            <h3>Custom Basketballs</h3>
            <p>Basketballs for training, retail, clubs and promotional campaigns with custom branding.</p>
            <ul class="list">
              <li>Indoor and outdoor options</li>
              <li>Custom logo and color designs</li>
              <li>Private label product development</li>
            </ul>
          </article>
          <article class="card">
            <div class="icon">🏀</div>
            <h3>Basketball Uniforms</h3>
            <p>Lightweight jerseys and shorts for teams, tournaments, clubs and online sellers.</p>
            <ul class="list">
              <li>Sublimated jersey and shorts sets</li>
              <li>Custom numbers and team colors</li>
              <li>Wholesale and club order support</li>
            </ul>
          </article>
          <article class="card">
            <div class="icon">🛡</div>
            <h3>Slip-in Shin Guards</h3>
            <p>Lightweight protective shin guards for football players, e-commerce sellers and team orders.</p>
            <ul class="list">
              <li>Heat-transfer artwork support</li>
              <li>Club, player and youth designs</li>
              <li>Private label packaging options</li>
            </ul>
          </article>
          <article class="card">
            <div class="icon">📦</div>
            <h3>Mixed Product Orders</h3>
            <p>Combine sports balls, uniforms, protective gear and packaging in one B2B sourcing project.</p>
            <ul class="list">
              <li>One supplier for multiple categories</li>
              <li>Flexible buyer and order types</li>
              <li>Export packing and shipment coordination</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section class="section soft">
      <div class="container">
        <div class="title">
          <div>
            <div class="kicker">Product Comparison</div>
            <h2>Choose the right product path for your order.</h2>
          </div>
          <p>Use this simple structure to match your business model with SaiWei Sport's production support.</p>
        </div>
        <table class="table">
          <tr>
            <th>Order Type</th>
            <th>Recommended Products</th>
            <th>Best For</th>
            <th>Customization Focus</th>
          </tr>
          <tr>
            <td>Wholesale Supply</td>
            <td>Footballs, basketballs, uniforms</td>
            <td>Distributors and retailers</td>
            <td>Logo, cartons, stable repeat orders</td>
          </tr>
          <tr>
            <td>Amazon Private Label</td>
            <td>Shin guards, balls, training products</td>
            <td>Marketplace sellers</td>
            <td>Packaging, product differentiation, listing-ready sets</td>
          </tr>
          <tr>
            <td>Club & Team Orders</td>
            <td>Football uniforms, basketball uniforms, shin guards</td>
            <td>Clubs, schools, academies</td>
            <td>Names, numbers, colors, badges</td>
          </tr>
          <tr>
            <td>Sports Brand OEM</td>
            <td>Full mixed collections</td>
            <td>Emerging and established brands</td>
            <td>Product line identity, packaging, artwork systems</td>
          </tr>
        </table>
      </div>
    </section>
  </main>
</Layout>
