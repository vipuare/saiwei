---
import Layout from '../layouts/Layout.astro';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact SaiWei Sport',
    url: 'https://saiweisport.com/contact',
    description: 'Request a custom sports goods quote from SaiWei Sport.',
    mainEntity: {
      '@type': 'Organization',
      name: 'SaiWei Sport',
      email: 'sales@saiweisport.com',
    },
  },
];
---

<Layout
  title="Contact SaiWei Sport | Request a Custom Sports Goods Quote"
  description="Contact SaiWei Sport to request a custom quote for footballs, basketballs, football uniforms, basketball uniforms and shin guards."
  activePage="contact"
  schema={schema}
>
  <main>
    <section class="pagehero">
      <div class="container">
        <div class="label"><span></span> Request a Quote</div>
        <h1>Tell us what sports products you want to customize.</h1>
        <p class="lead">Send your product type, quantity, logo files, target market and packaging requirements. SaiWei Sport will help prepare a custom order plan.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="quote">
          <div class="quote-text">
            <div class="kicker">Start Your Project</div>
            <h2>Bring us any sports order. We will help build the right supply plan.</h2>
            <p>SaiWei Sport accepts wholesale orders, Amazon private-label orders, brand OEM/ODM projects, club team orders, promotional products and mixed-category sourcing.</p>
            <div class="contactinfo">
              <div class="contactbox">
                <strong>Email</strong>
                <span>sales@saiweisport.com</span>
              </div>
              <div class="contactbox">
                <strong>Buyer Focus</strong>
                <span>Wholesalers · Amazon Sellers · Sports Brands · Clubs · Distributors</span>
              </div>
              <div class="contactbox">
                <strong>Product Range</strong>
                <span>Football · Football Uniforms · Basketball · Basketball Uniforms · Shin Guards</span>
              </div>
            </div>
          </div>
          <form class="form" id="inquiry-form">
            <input type="text" name="name" placeholder="Your Name / Company" required />
            <input type="email" name="email" placeholder="Business Email" required />
            <select name="buyer_type">
              <option value="">Buyer Type</option>
              <option>Wholesaler / Distributor</option>
              <option>Amazon / Online Seller</option>
              <option>Sports Brand</option>
              <option>Club / Academy / Team</option>
              <option>Promotional Buyer</option>
            </select>
            <select name="product">
              <option value="">Product Interest</option>
              <option>Custom Footballs</option>
              <option>Football Uniforms</option>
              <option>Custom Basketballs</option>
              <option>Basketball Uniforms</option>
              <option>Slip-in Shin Guards</option>
              <option>Mixed Products</option>
            </select>
            <input type="text" name="quantity" placeholder="Estimated Quantity" />
            <input type="text" name="market" placeholder="Target Market / Country" />
            <textarea name="message" placeholder="Tell us your logo, colors, sizes, artwork, packaging, shipping and delivery requirements."></textarea>
            <div id="form-status" class="form-status"></div>
            <button class="btn btn-green" type="submit" id="submit-btn">Submit Custom Inquiry</button>
          </form>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .form-status {
    text-align: center;
    font-size: 14px;
    min-height: 20px;
    margin-bottom: 8px;
  }
  .form-status.success {
    color: #16a34a;
  }
  .form-status.error {
    color: #dc2626;
  }
  #submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>

<script>
  const form = document.getElementById('inquiry-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    status.textContent = 'Sending...';
    status.className = 'form-status';

    const data = {
      name: (form.querySelector('[name="name"]') as HTMLInputElement).value,
      email: (form.querySelector('[name="email"]') as HTMLInputElement).value,
      buyer_type: (form.querySelector('[name="buyer_type"]') as HTMLSelectElement).value,
      product: (form.querySelector('[name="product"]') as HTMLSelectElement).value,
      quantity: (form.querySelector('[name="quantity"]') as HTMLInputElement).value,
      market: (form.querySelector('[name="market"]') as HTMLInputElement).value,
      message: (form.querySelector('[name="message"]') as HTMLTextAreaElement).value,
      source: 'website',
    };

    try {
      const res = await fetch('/api/inquiry', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = await res.json();

      if (res.ok && result.success) {
        status.textContent = 'Thank you! Your inquiry has been submitted. We will contact you soon.';
        status.className = 'form-status success';
        form.reset();
      } else {
        status.textContent = result.error || 'Something went wrong. Please try again.';
        status.className = 'form-status error';
      }
    } catch {
      status.textContent = 'Network error. Please check your connection and try again.';
      status.className = 'form-status error';
    } finally {
      btn.disabled = false;
    }
  });
</script>
