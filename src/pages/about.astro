---
import Layout from '../layouts/Layout.astro';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'SaiWei Sport',
    url: 'https://saiweisport.com',
    description: 'Custom sports goods supplier for global wholesalers, Amazon sellers, sports brands, clubs and distributors.',
    knowsAbout: ['Custom Footballs', 'Football Uniforms', 'Custom Basketballs', 'Basketball Uniforms', 'Shin Guards'],
  },
];
---

<Layout
  title="About SaiWei Sport | Custom Sports Goods Supplier"
  description="SaiWei Sport is a custom sports goods supplier for global wholesalers, Amazon sellers, sports brands, clubs and distributors."
  activePage="about"
  schema={schema}
>
  <main>
    <section class="pagehero">
      <div class="container">
        <div class="label"><span></span> About SaiWei Sport</div>
        <h1>A custom sports goods supplier for global buyers.</h1>
        <p class="lead">SaiWei Sport serves wholesalers, Amazon sellers, sports brands, clubs and distributors with custom footballs, basketballs, uniforms and shin guards.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="split">
          <div class="big">
            <div class="kicker">Brand Position</div>
            <h2>Factory supply with a stronger sports brand feeling.</h2>
            <p>We are not trying to look like a generic catalog supplier. SaiWei Sport is built around a cleaner green-white football identity, professional B2B communication and a practical OEM/ODM service system.</p>
            <p>Our goal is to help buyers create products that are easier to sell, easier to present and easier to reorder.</p>
          </div>
          <div class="timeline">
            <div class="time">
              <strong>Global Market</strong>
              <p>Serving international buyers with Europe as a key market focus.</p>
            </div>
            <div class="time">
              <strong>Buyer Types</strong>
              <p>Wholesalers, Amazon sellers, private-label brands, clubs and distributors.</p>
            </div>
            <div class="time">
              <strong>Core Products</strong>
              <p>Footballs, football uniforms, basketballs, basketball uniforms and shin guards.</p>
            </div>
            <div class="time">
              <strong>Order Capability</strong>
              <p>Wholesale, private label, mixed category, promotional and team orders.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section soft">
      <div class="container">
        <div class="title">
          <div>
            <div class="kicker">Why Choose Us</div>
            <h2>A clearer partner for custom sports goods.</h2>
          </div>
          <p>SaiWei Sport helps buyers reduce communication friction and turn custom sports product ideas into real orders.</p>
        </div>
        <div class="grid3">
          <article class="card">
            <h3>Multi-category Sourcing</h3>
            <p>Source balls, uniforms and protective gear through one communication path.</p>
          </article>
          <article class="card">
            <h3>Brand-first Customization</h3>
            <p>Upgrade ordinary products with coordinated colors, logos, packaging and product presentation.</p>
          </article>
          <article class="card">
            <h3>B2B Order Flexibility</h3>
            <p>Support wholesale, Amazon, club, promotional, distributor and private label orders.</p>
          </article>
        </div>
      </div>
    </section>
  </main>
</Layout>
