---
import Layout from '../layouts/Layout.astro';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Manufacturer',
    name: 'SaiWei Sport Factory',
    url: 'https://saiweisport.com/factory',
    description: 'SaiWei Sport factory with OEM/ODM capabilities including product development, sampling, quality inspection and export packing.',
    address: { '@type': 'PostalAddress', addressCountry: 'CN' },
  },
];
---

<Layout
  title="Factory Strength | SaiWei Sport Sports Goods Manufacturer"
  description="Learn about SaiWei Sport factory strength, sampling, production, quality inspection, export packing and multi-category sports goods supply."
  activePage="factory"
  schema={schema}
>
  <main>
    <section class="pagehero">
      <div class="container">
        <div class="label"><span></span> Factory Strength</div>
        <h1>Factory confidence with premium brand execution.</h1>
        <p class="lead">SaiWei Sport combines practical manufacturing support with a brand-focused custom process, helping international buyers source sports goods with confidence.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="factory">
          <div class="factory-grid">
            <div class="badge">
              <div>
                <strong>OEM<br />ODM</strong>
                <span>Factory System</span>
              </div>
            </div>
            <div class="caps">
              <div class="cap">
                <strong>Product Development</strong>
                <p>Support for selecting materials, colors, surface finishes, sizes, artwork and order combinations.</p>
              </div>
              <div class="cap">
                <strong>Sampling Before Bulk</strong>
                <p>Digital mockups and sampling workflow help buyers confirm details before mass production.</p>
              </div>
              <div class="cap">
                <strong>Multi-category Supply</strong>
                <p>Football, basketball, uniforms and shin guards can be sourced together for easier procurement.</p>
              </div>
              <div class="cap">
                <strong>Export Packing</strong>
                <p>Cartons, labels, packaging details and shipping coordination for international B2B orders.</p>
              </div>
              <div class="cap">
                <strong>Quality Inspection</strong>
                <p>Check printing, stitching, ball finish, protective gear appearance and package consistency.</p>
              </div>
              <div class="cap">
                <strong>Flexible Order Types</strong>
                <p>Wholesale, private label, Amazon, clubs, events, promotional and brand development orders.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section soft">
      <div class="container">
        <div class="split">
          <div class="big">
            <div class="kicker">Production Mindset</div>
            <h2>Built for repeat B2B orders.</h2>
            <p>For wholesalers, Amazon sellers and sports brands, consistency matters. SaiWei Sport focuses on confirming product details clearly before production and supporting export-ready packing for international orders.</p>
            <div class="pills">
              <span class="pill">Sampling</span>
              <span class="pill">Inspection</span>
              <span class="pill">Carton Packing</span>
              <span class="pill">Export Support</span>
            </div>
          </div>
          <div class="timeline">
            <div class="time">
              <strong>01 · Pre-production Review</strong>
              <p>Confirm product type, quantity, specifications, artwork, packaging and buyer requirements.</p>
            </div>
            <div class="time">
              <strong>02 · Sampling & Detail Check</strong>
              <p>Prepare samples or mockups for logo position, color matching, size and packaging direction.</p>
            </div>
            <div class="time">
              <strong>03 · Bulk Production</strong>
              <p>Organize production according to confirmed specifications and delivery schedule.</p>
            </div>
            <div class="time">
              <strong>04 · Packing & Shipping Support</strong>
              <p>Arrange product packing, carton marks and export shipment coordination for global buyers.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
